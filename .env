# ═══════════════════════════════════════════════════════════════════════════
# Appasamy Product Commitment — Frontend Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file as .env in your project root.
# Restart the dev server (npm start) after any changes.
#
# ═══════════════════════════════════════════════════════════════════════════


# ── AUTH MODE ──────────────────────────────────────────────────────────────
# true  = Mock login with demo accounts (no backend needed)
# false = Live backend API login
REACT_APP_USE_MOCK=true


# ── BACKEND API URL ───────────────────────────────────────────────────────
# Used when USE_MOCK=false
# Development:
REACT_APP_API_URL=http://localhost:5000/api/v1
# Production (example):
# REACT_APP_API_URL=https://api.appasamy.com/api/v1


# ── SSO (Microsoft Azure AD) ─────────────────────────────────────────────
# Set to true to show "Sign in with Microsoft" button on login page
REACT_APP_SSO_ENABLED=false

# Azure AD App Registration — fill these when enabling SSO
REACT_APP_AZURE_CLIENT_ID=
REACT_APP_AZURE_TENANT_ID=
REACT_APP_AZURE_REDIRECT_URI=http://localhost:3000
REACT_APP_AZURE_POST_LOGOUT_URI=http://localhost:3000/login

# Comma-separated emails that auto-get admin role on first SSO login
REACT_APP_DEFAULT_ADMIN_EMAILS=muthu@appasamy.com,yoga@appasamy.com


# ═══════════════════════════════════════════════════════════════════════════
# QUICK START GUIDE
# ═══════════════════════════════════════════════════════════════════════════
#
# STEP 1 — Development (mock, no backend):
#   REACT_APP_USE_MOCK=true
#   REACT_APP_SSO_ENABLED=false
#   → Login with: salesrep/demo123, tbm/demo123, abm/demo123, etc.
#
# STEP 2 — Connect backend (API live, no SSO):
#   REACT_APP_USE_MOCK=false
#   REACT_APP_API_URL=http://your-server:5000/api/v1
#   REACT_APP_SSO_ENABLED=false
#
# STEP 3 — Enable SSO (backend + Azure AD):
#   REACT_APP_USE_MOCK=false
#   REACT_APP_API_URL=http://your-server:5000/api/v1
#   REACT_APP_SSO_ENABLED=true
#   REACT_APP_AZURE_CLIENT_ID=your-client-id
#   REACT_APP_AZURE_TENANT_ID=your-tenant-id
#
# ═══════════════════════════════════════════════════════════════════════════
